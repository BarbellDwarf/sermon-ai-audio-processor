#!/usr/bin/env python3
"""
Pre-commit hook to detect hardcoded credentials and security violations
Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
"""

import os
import re
import sys
import subprocess
from pathlib import Path
from typing import List, Tuple


def get_staged_files() -> List[str]:
    """Get list of staged files for commit."""
    try:
        result = subprocess.run(
            ['git', 'diff', '--cached', '--name-only'],
            capture_output=True,
            text=True,
            check=True
        )
        return [f.strip() for f in result.stdout.splitlines() if f.strip()]
    except subprocess.CalledProcessError:
        return []


def scan_staged_content(file_path: str) -> List[Tuple[int, str, str]]:
    """Scan staged content of a file for security violations."""
    violations = []
    
    # Patterns for detecting hardcoded credentials
    credential_patterns = {
        'API Key': r'api_key\s*[:=]\s*["\']?([a-zA-Z0-9-]{20,})["\']?',
        'OpenAI Key': r'["\']?(sk-[a-zA-Z0-9]{32,})["\']?',
        'xAI Key': r'["\']?(xai-[a-zA-Z0-9]{20,})["\']?',
        'Anthropic Key': r'["\']?(sk-ant-[a-zA-Z0-9]{20,})["\']?',
        'Groq Key': r'["\']?(gsk-[a-zA-Z0-9]{20,})["\']?',
        'Password': r'password\s*[:=]\s*["\']?([^$][^{][^}]+)["\']?',
        'Secret': r'secret\s*[:=]\s*["\']?([a-zA-Z0-9]{16,})["\']?',
        'Token': r'token\s*[:=]\s*["\']?([a-zA-Z0-9-_]{20,})["\']?',
    }
    
    # Test data patterns
    test_patterns = [
        'your-api-key-here', 'your-broadcaster-id', 'test_key', 'test_broadcaster',
        'example.com', 'demo.com', 'changeme', 'password123', '12345'
    ]
    
    try:
        # Get staged content for this file
        result = subprocess.run(
            ['git', 'show', f':{file_path}'],
            capture_output=True,
            text=True,
            check=True
        )
        content = result.stdout
        
        for line_num, line in enumerate(content.splitlines(), 1):
            # Skip comments and empty lines
            if not line.strip() or line.strip().startswith('#'):
                continue
            
            # Check for credential patterns
            for cred_type, pattern in credential_patterns.items():
                if re.search(pattern, line, re.IGNORECASE):
                    # Skip if it's an environment variable reference
                    if '${' in line or '$' in line.upper():
                        continue
                    violations.append((line_num, cred_type, line.strip()))
            
            # Check for test data patterns (but skip actual test files)
            if not any(test_dir in file_path.lower() for test_dir in ['test', 'example', 'demo']):
                for test_pattern in test_patterns:
                    if test_pattern.lower() in line.lower():
                        # Skip if in a comment
                        if '#' in line and line.index('#') < line.find(test_pattern):
                            continue
                        violations.append((line_num, 'Test Data', line.strip()))
                        break
        
    except subprocess.CalledProcessError:
        # File might be deleted or renamed
        pass
    
    return violations


def main():
    """Main pre-commit hook function."""
    print("🔍 Running security pre-commit check...")
    
    staged_files = get_staged_files()
    if not staged_files:
        print("✅ No staged files to check")
        return 0
    
    # Filter for relevant file types
    relevant_extensions = {'.py', '.yaml', '.yml', '.json', '.md', '.txt', '.cfg', '.ini'}
    files_to_check = [
        f for f in staged_files 
        if Path(f).suffix.lower() in relevant_extensions
    ]
    
    if not files_to_check:
        print("✅ No relevant files to check for security violations")
        return 0
    
    total_violations = 0
    critical_violations = 0
    
    for file_path in files_to_check:
        violations = scan_staged_content(file_path)
        if violations:
            print(f"\n❌ Security violations found in {file_path}:")
            for line_num, violation_type, line_content in violations:
                print(f"   Line {line_num}: {violation_type}")
                print(f"      {line_content}")
                total_violations += 1
                if violation_type in ['API Key', 'OpenAI Key', 'xAI Key', 'Anthropic Key', 'Groq Key', 'Password', 'Secret', 'Token']:
                    critical_violations += 1
    
    if total_violations > 0:
        print(f"\n🚫 COMMIT BLOCKED: {total_violations} security violations detected!")
        print(f"   Critical violations: {critical_violations}")
        print(f"   Total violations: {total_violations}")
        print("\n🔧 To fix these issues:")
        print("   1. Replace hardcoded credentials with environment variables")
        print("   2. Use ${VARIABLE_NAME} syntax in config files")
        print("   3. Move test data to proper test fixtures")
        print("   4. Create a .env file for local development")
        print("\n💡 Example fixes:")
        print("   api_key: 'sk-abcd1234...' → api_key: '${OPENAI_API_KEY}'")
        print("   password: 'mypassword' → password: '${DATABASE_PASSWORD}'")
        print("   broadcaster_id: '12345' → broadcaster_id: '${SERMONAUDIO_BROADCASTER_ID}'")
        print("\n📚 See .env.example for the complete list of environment variables")
        return 1
    
    print(f"✅ Security check passed for {len(files_to_check)} files")
    return 0


if __name__ == "__main__":
    sys.exit(main())